# x64dbg MCP Server Configuration

# Path to x64dbg installation directory
X64DBG_PATH=C:\x64dbg

# Bridge connection settings
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=27042

# Logging level: error, warn, info, debug
LOG_LEVEL=info

# Session settings
MAX_SESSIONS=5
SESSION_TIMEOUT_MS=3600000

# Analysis settings
MAX_DISASM_INSTRUCTIONS=500
MAX_TRACE_INSTRUCTIONS=10000
MAX_SEARCH_RESULTS=1000
MAX_STRING_LENGTH=256
