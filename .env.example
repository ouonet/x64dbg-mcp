# x64dbg MCP Server Configuration

# Path to x64dbg installation directory
X64DBG_PATH=C:\x64dbg

# Python installation directories for the bridge plugin C loader.
# Set these to avoid copying python DLLs into the x64dbg plugins folder.
# The loader picks PYTHON_HOME_X64 for the 64-bit plugin (.dp64) and
# PYTHON_HOME_X86 for the 32-bit plugin (.dp32).
# Leave blank to fall back to PATH / hard-coded locations.
PYTHON_HOME_X64=C:\Python314
PYTHON_HOME_X86=C:\Python312-32

# Bridge connection settings
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=27042

# Shared secret for localhost bridge requests (REQUIRED).
# Run "npm run setup" to generate and populate this automatically.
# The server will refuse to start if this is empty.
BRIDGE_AUTH_TOKEN=

# Logging level: error, warn, info, debug
LOG_LEVEL=info

# MCP transport: stdio (default) or streamable-http
MCP_TRANSPORT=stdio

# HTTP transport settings (used when MCP_TRANSPORT=streamable-http)
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000

# Session settings (the current bridge architecture supports exactly one active session)
MAX_SESSIONS=1
SESSION_TIMEOUT_MS=3600000

# Analysis settings
MAX_DISASM_INSTRUCTIONS=500
MAX_TRACE_INSTRUCTIONS=10000
MAX_SEARCH_RESULTS=1000
MAX_STRING_LENGTH=256
