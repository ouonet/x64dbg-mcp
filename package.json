{
  "name": "x64dbg-mcp",
  "version": "1.1.0",
  "description": "Production-level Model Context Protocol server for x64dbg reverse engineering and debugging",
  "type": "module",
  "main": "dist/server.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ouonet/x64dbg-mcp.git"
  },
  "homepage": "https://github.com/ouonet/x64dbg-mcp#readme",
  "bugs": {
    "url": "https://github.com/ouonet/x64dbg-mcp/issues"
  },
  "bin": {
    "x64dbg-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "sync-plugin": "node scripts/sync-plugin.mjs",
    "predev": "node scripts/sync-plugin.mjs",
    "dev": "tsx src/server.ts",
    "inspector": "npx @modelcontextprotocol/inspector node dist/server.js",
    "test": "npx tsx --test test/basic.test.ts test/service/paths.test.ts test/service/installed-json.test.ts test/service/env-snapshot.test.ts test/service/privilege.test.ts test/service/health-check.test.ts test/service/elevate-runner.test.ts test/service/status-formatter.test.ts test/service/cli-parsing.test.ts test/service/error-codes.test.ts",
    "test:service:integration": "npx tsx --test test/service/integration/lifecycle.integration.test.ts test/service/integration/reinstall.integration.test.ts test/service/integration/port-conflict.integration.test.ts test/service/integration/env-edit.integration.test.ts",
    "test:e2e": "node test/e2e/test_mcp_client.mjs",
    "test:http-smoke": "npm run build && node scripts/manual/test_http_transport.mjs",
    "test:http-smoke:attach:process-name": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/manual/run_http_attach_process_name_smoke.ps1",
    "test:service:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/manual/run_service_smoke.ps1",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "setup": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "install-plugin": "node scripts/install-plugin.mjs",
    "setup-x64dbg": "node scripts/setup-x64dbg.mjs",
    "ci": "node scripts/ci.mjs",
    "prepack": "node scripts/prepack.mjs",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "files": [
    "dist/",
    "LICENSE",
    "scripts/postinstall.mjs",
    "scripts/prepack.mjs",
    "scripts/bridge-auth.mjs",
    "scripts/setup-x64dbg.mjs",
    "scripts/setup.mjs",
    "scripts/sync-plugin.mjs",
    "scripts/doctor.mjs",
    "scripts/install-plugin.mjs",
    "scripts/install-plugin.ps1",
    "plugin/x64dbg_mcp_bridge.py",
    "plugin/x64dbg_bridge_sdk.py",
    "plugin/loader/prebuilt/",
    ".env.example",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "mcp",
    "x64dbg",
    "debugger",
    "reverse-engineering",
    "binary-analysis",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.5.0",
    "node-windows": "^1.0.0-beta.8",
    "winston": "^3.17.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/node-windows": "^0.1.6",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
